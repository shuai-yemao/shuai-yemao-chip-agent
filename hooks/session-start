#!/usr/bin/env bash
# Chip System — session-start hook
# 1. 输出 SOUL.md 和 AGENTS.md 到 stdout（注入系统提示）
# 2. 自动启动 DeepSeek API 代理（端口 17999）

HOME_DIR="$HOME"
CLAUDE_DIR="$HOME_DIR/.claude"

# Part 1: 输出 SOUL.md 和 AGENTS.md
if [ -f "$CLAUDE_DIR/SOUL.md" ]; then
    echo ""
    echo "===== SOUL.md (Chip 人格 — 系统级架构师) ====="
    cat "$CLAUDE_DIR/SOUL.md"
    echo ""
    echo "===== End of SOUL.md ====="
    echo ""
fi

if [ -f "$CLAUDE_DIR/AGENTS.md" ]; then
    echo "===== AGENTS.md (AI 行为守则) ====="
    cat "$CLAUDE_DIR/AGENTS.md"
    echo ""
    echo "===== End of AGENTS.md ====="
    echo ""
fi

# Part 2: 自动启动 DeepSeek API 代理
PROXY_PORT=17999
PROXY_SCRIPT="$CLAUDE_DIR/bin/deepseek-proxy.js"
LOG_FILE="$CLAUDE_DIR/hooks/proxy-startup.log"

if netstat -ano 2>/dev/null | grep -q ":${PROXY_PORT} " || \
   ss -tlnp 2>/dev/null | grep -q ":${PROXY_PORT} "; then
    exit 0
fi

if [ ! -f "${PROXY_SCRIPT}" ]; then
    echo "[$(date)] proxy script not found" >> "${LOG_FILE}"
    exit 1
fi

nohup node "${PROXY_SCRIPT}" >> "${LOG_FILE}" 2>&1 &
PID=$!
sleep 2
if kill -0 "${PID}" 2>/dev/null; then
    echo "[$(date)] proxy started on port ${PROXY_PORT} (PID: ${PID})" >> "${LOG_FILE}"
else
    echo "[$(date)] proxy failed to start" >> "${LOG_FILE}"
fi
